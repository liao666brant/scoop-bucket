{
  "version": "0.0.0",
  "description": "Terminal-native coding agent for DeepSeek models.",
  "homepage": "https://github.com/Hmbown/DeepSeek-TUI",
  "license": "MIT",
  "architecture": {
    "64bit": {
      "url": [
        "https://github.com/Hmbown/DeepSeek-TUI/releases/latest/download/deepseek-windows-x64.exe#/deepseek.exe",
        "https://github.com/Hmbown/DeepSeek-TUI/releases/latest/download/deepseek-tui-windows-x64.exe#/deepseek-tui.exe"
      ],
      "hash": [
        "skip",
        "skip"
      ]
    }
  },
  "bin": [
    "deepseek.exe",
    "deepseek-tui.exe"
  ],
  "checkver": {
    "github": "https://github.com/Hmbown/DeepSeek-TUI"
  },
  "autoupdate": {
    "architecture": {
      "64bit": {
        "url": [
          "https://github.com/Hmbown/DeepSeek-TUI/releases/download/v$version/deepseek-windows-x64.exe#/deepseek.exe",
          "https://github.com/Hmbown/DeepSeek-TUI/releases/download/v$version/deepseek-tui-windows-x64.exe#/deepseek-tui.exe"
        ]
      }
    }
  },
  "notes": [
    "Both deepseek.exe and deepseek-tui.exe are installed because the dispatcher delegates to the TUI runtime.",
    "Run 'deepseek auth set --provider deepseek' to configure your DeepSeek API key.",
    "Then run 'deepseek' to start the terminal UI."
  ]
}
