{
  "version": "0.0.0",
  "description": "A Go CLI proxy that lets you use an OpenCode Go subscription with Claude Code.",
  "homepage": "https://github.com/samueltuyizere/oc-go-cc",
  "license": "MIT",
  "architecture": {
    "64bit": {
      "url": "https://github.com/samueltuyizere/oc-go-cc/releases/latest/download/oc-go-cc_windows-amd64.exe#/oc-go-cc.exe",
      "hash": "skip"
    },
    "arm64": {
      "url": "https://github.com/samueltuyizere/oc-go-cc/releases/latest/download/oc-go-cc_windows-arm64.exe#/oc-go-cc.exe",
      "hash": "skip"
    }
  },
  "bin": "oc-go-cc.exe",
  "checkver": {
    "github": "https://github.com/samueltuyizere/oc-go-cc"
  },
  "autoupdate": {
    "architecture": {
      "64bit": {
        "url": "https://github.com/samueltuyizere/oc-go-cc/releases/download/v$version/oc-go-cc_windows-amd64.exe#/oc-go-cc.exe",
        "hash": {
          "url": "$baseurl/checksums.txt",
          "regex": "$sha256\\s+oc-go-cc_windows-amd64\\.exe"
        }
      },
      "arm64": {
        "url": "https://github.com/samueltuyizere/oc-go-cc/releases/download/v$version/oc-go-cc_windows-arm64.exe#/oc-go-cc.exe",
        "hash": {
          "url": "$baseurl/checksums.txt",
          "regex": "$sha256\\s+oc-go-cc_windows-arm64\\.exe"
        }
      }
    }
  },
  "notes": [
    "Run 'oc-go-cc init' to create the default config.",
    "Set OC_GO_CC_API_KEY before using the proxy.",
    "Then run 'oc-go-cc serve'."
  ]
}
